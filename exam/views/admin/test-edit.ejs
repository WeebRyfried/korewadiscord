<section class="page-heading">
  <div>
    <p class="eyebrow">Admin editor</p>
    <h1><%= test.title %></h1>
  </div>
  <a class="button secondary" href="<%= url('/admin/tests') %>">Back to tests</a>
</section>

<section class="panel">
  <h2>Test settings</h2>
  <form method="post" action="<%= url(`/admin/tests/${test.id}`) %>" class="editor-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Title
      <input name="title" type="text" value="<%= test.title %>" required>
    </label>
    <label>Description
      <textarea name="description" rows="2"><%= test.description %></textarea>
    </label>
    <label>Instructions
      <textarea name="instructions" rows="4"><%= test.instructions %></textarea>
    </label>
    <div class="form-grid">
      <label>Status
        <select name="status">
          <option value="OPENED" <%= test.status === 'OPENED' ? 'selected' : '' %>>OPENED</option>
          <option value="CLOSED" <%= test.status === 'CLOSED' ? 'selected' : '' %>>CLOSED</option>
        </select>
      </label>
      <label>Timer seconds per question
        <input name="timer_seconds_per_question" type="number" min="10" max="3600" value="<%= test.timer_seconds_per_question %>">
      </label>
      <label class="checkbox-label">
        <input name="randomize_questions" type="checkbox" value="1" <%= test.randomize_questions ? 'checked' : '' %>>
        Randomized question set per attempt
      </label>
      <label>Questions shown per attempt
        <input name="question_limit" type="number" min="1" max="<%= Math.max(test.question_count, 1) %>" value="<%= test.question_limit || '' %>" placeholder="All">
        <span class="row-note">Use 10 to show a random 10 from the question bank. Leave blank to use all <%= test.question_count %> questions.</span>
      </label>
    </div>
    <div class="action-row">
      <button class="button" type="submit">Save settings</button>
    </div>
  </form>
  <form method="post" action="<%= url(`/admin/tests/${test.id}/archive`) %>" class="danger-row">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button class="button secondary" type="submit">Archive test</button>
  </form>
  <form method="post" action="<%= url(`/admin/tests/${test.id}/delete`) %>" class="danger-row" onsubmit="return confirm('Delete this test and all attempts? This cannot be undone.');">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button class="button danger" type="submit">Delete test</button>
  </form>
</section>

<section class="panel">
  <h2>Add question</h2>
  <form method="post" action="<%= url(`/admin/tests/${test.id}/questions`) %>" class="editor-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-grid">
      <label>Question type
        <select name="question_type">
          <option value="MULTIPLE_CHOICE">Multiple choice</option>
          <option value="SHORT_ESSAY">Short essay</option>
        </select>
      </label>
      <label>Question text
        <input name="question_text" type="text" required>
      </label>
    </div>
    <button class="button" type="submit">Add question</button>
  </form>
</section>

<section class="question-list">
  <% test.questions.forEach((question) => { %>
    <article class="panel question-admin">
      <div class="question-title-row">
        <h2>Question <%= question.position %></h2>
        <span class="status neutral"><%= question.question_type %></span>
      </div>

      <form method="post" action="<%= url(`/admin/questions/${question.id}`) %>" class="editor-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-grid position-grid">
          <label>Position
            <input name="position" type="number" min="1" value="<%= question.position %>">
          </label>
          <label>Question text
            <textarea name="question_text" rows="3"><%= question.question_text %></textarea>
          </label>
        </div>
        <% if (question.question_type === 'SHORT_ESSAY') { %>
          <label>Sample answer for AI grading
            <textarea name="sample_answer" rows="3" placeholder="Reference answer used by DeepSeek to grade this essay"><%= question.sample_answer || '' %></textarea>
            <span class="row-note">DeepSeek grades submitted answers as 0, 0.5, or 1 against this sample answer.</span>
          </label>
        <% } %>
        <div class="action-row">
          <button class="button small" type="submit">Save question</button>
        </div>
      </form>

      <% if (question.question_type === 'MULTIPLE_CHOICE') { %>
        <div class="options-editor">
          <h3>Options</h3>
          <form method="post" action="<%= url(`/admin/questions/${question.id}/options/bulk`) %>" class="options-bulk-form" data-options-form>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <% question.options.forEach((option) => { %>
              <div class="option-row">
                <input name="options[option_<%= option.id %>][position]" type="number" min="1" value="<%= option.position %>" aria-label="Option position">
                <input name="options[option_<%= option.id %>][option_text]" type="text" value="<%= option.option_text %>" aria-label="Option text">
                <label class="checkbox-label">
                  <input name="options[option_<%= option.id %>][is_correct]" type="checkbox" value="1" <%= option.is_correct ? 'checked' : '' %>>
                  Correct
                </label>
                <label class="checkbox-label option-delete">
                  <input name="options[option_<%= option.id %>][delete]" type="checkbox" value="1">
                  Delete
                </label>
              </div>
            <% }) %>
            <div class="new-options" data-new-options></div>
            <template data-option-template>
              <div class="option-row">
                <input name="new_options[__INDEX__][position]" type="number" min="1" aria-label="New option position">
                <input name="new_options[__INDEX__][option_text]" type="text" placeholder="New option text" aria-label="New option text">
                <label class="checkbox-label">
                  <input name="new_options[__INDEX__][is_correct]" type="checkbox" value="1">
                  Correct
                </label>
                <span></span>
              </div>
            </template>
            <div class="action-row">
              <button class="button small secondary" type="button" data-add-option>Add option row</button>
              <button class="button small" type="submit">Save options</button>
            </div>
          </form>
        </div>
      <% } %>

      <form method="post" action="<%= url(`/admin/questions/${question.id}/delete`) %>" class="danger-row">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="link-danger" type="submit">Delete question</button>
      </form>
    </article>
  <% }) %>
</section>

<script src="<%= url('/assets/js/admin-test-edit.js') %>?v=20260524-options"></script>
