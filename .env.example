# Copy this file to .env on your local machine and on the VPS.
# Do not commit .env. Use strong production values.

COMPOSE_PROJECT_NAME=korewadiscord

# Local default can be 80. On the VPS, use 127.0.0.1:8088 when host Nginx already owns port 80.
NGINX_HTTP_BIND=80

# Public origin used by MediaWiki when it generates links.
MEDIAWIKI_SERVER=https://underground.korewadiscord.com
MEDIAWIKI_SITE_NAME="KorewaDiscord Underground Wiki"
MEDIAWIKI_SCRIPT_PATH=/wiki
MEDIAWIKI_DEFAULT_SKIN=vector-2022
MEDIAWIKI_ALLOW_ANON_EDIT=true

# MediaWiki admin bootstrap account.
MEDIAWIKI_ADMIN_USER=ryfried
MEDIAWIKI_ADMIN_PASSWORD=change-this-in-real-env

# MediaWiki MariaDB credentials.
MEDIAWIKI_DB_NAME=mediawiki
MEDIAWIKI_DB_USER=mediawiki
MEDIAWIKI_DB_PASSWORD=change-this-in-real-env
MEDIAWIKI_DB_ROOT_PASSWORD=change-this-root-password

# Exam admin account and session signing secret.
EXAM_ADMIN_USER=ryfried
EXAM_ADMIN_PASSWORD=change-this-in-real-env
EXAM_SESSION_SECRET=replace-with-a-long-random-secret
# Use false for local http://localhost testing. Use true on the VPS behind Cloudflare HTTPS.
EXAM_COOKIE_SECURE=false

# Optional Cloudflare DNS helper values for scripts/cloudflare-dns.sh.
CF_API_TOKEN=
CF_ZONE_ID=
CF_RECORD_NAME=underground
ORIGIN_IP=

# Optional: DeepSeek essay grading for /exam short-answer questions.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
